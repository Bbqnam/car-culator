# Backend proxy (used by `npm run dev:api`)
XAI_API_KEY=
XAI_MODEL=grok-3-mini
XAI_API_URL=https://api.x.ai/v1/chat/completions
CARAI_PROXY_PORT=8787
CARAI_ALLOWED_ORIGIN=http://localhost:8080
# Legacy fallback:
# GROK_PROXY_PORT=8787
# GROK_ALLOWED_ORIGIN=http://localhost:8080

# Frontend (Vite)
VITE_CARAI_CHAT_API_URL=/api/carai-chat
# Legacy fallback (still supported):
# VITE_GROK_CHAT_API_URL=/api/grok-chat
CARAI_PROXY_TARGET=http://localhost:8787
# Legacy fallback:
# GROK_PROXY_TARGET=http://localhost:8787
VITE_XAI_BROWSER_API_URL=https://api.x.ai/v1/chat/completions
VITE_XAI_MODEL=grok-3-mini
VITE_OLLAMA_CHAT_API_URL=http://localhost:11434/v1/chat/completions
VITE_OLLAMA_MODEL=llama3.2:1b
